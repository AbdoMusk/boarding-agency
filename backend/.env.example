# ─── Copy this file to .env and fill in the values ───────────────────────────

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development
DEBUG=true

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Switch between "gemini" (cloud) or "ollama" (local)
LLM_PROVIDER=gemini

# Google Gemini (cloud) – get your key at https://aistudio.google.com/
GOOGLE_AI_STUDIO_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local) – run `ollama serve` to start
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_OCR_MODEL=glm-ocr
OLLAMA_LLM_MODEL=gemma3

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config)
DATABASE_URL=sqlite:///boarding.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/boarding

# ─── Caching ──────────────────────────────────────────────────────────────────
# Strategy: "memory" | "file" | "redis"
CACHE_STRATEGY=file
CACHE_DIR=cache
CACHE_TTL_SECONDS=86400

# Redis URL (only needed if CACHE_STRATEGY=redis)
REDIS_URL=redis://localhost:6379/0

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
IMAGES_FOLDER=images
OUTPUTS_FOLDER=outputs
PDF_DPI=200

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Matching Defaults ────────────────────────────────────────────────────────
DEFAULT_REQUIRED_SKILLS=communication,teamwork,english
DEFAULT_MIN_EXPERIENCE=0
